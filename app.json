{
  "expo": {
    "name": "AMI mobile",
    "slug": "esgul-service-pro",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "scheme": "esgulepro",
    "updates": {
      "enabled": false
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
    },
    "android": {
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.aqilmunifindyana.esgulservicepro",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#191612"
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermissions": "Allow ESGUL Service Pro to access your location."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "b396dea7-b2a7-450d-9504-59e5f86b35ac"
      }
    }
  }
}
